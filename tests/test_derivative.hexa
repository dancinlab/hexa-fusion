#!hexa strict
// hexa-fusion/tests/test_derivative.hexa — sentinel sweep for derivative
// modules added in the sscb-pattern composition extension (margin / whatif
// / sensitivity / archetype / doctor / status / pillar).
//
// Pattern: each module emits a `__FUSION_<MODULE>__ <PASS|FAIL>` sentinel
// on stdout. This test executes each module locally (HEXA_FUSION_ROOT
// inferred from `pwd`) and asserts the sentinel.
//
// Bench-independent: pure closed-form arithmetic + filesystem checks; no
// external deps beyond the hexa runtime itself.

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _run(name: str, path: str, args: str) -> str {
    let cmd = "hexa run \"" + path + "\" " + args + " 2>&1"
    return exec(cmd)
}

fn _check(name: str, output: str, expected: str) -> bool {
    if output.contains(expected) {
        println("  [PASS] " + name)
        return true
    }
    println("  [FAIL] " + name + "  expected sentinel: " + expected)
    println("         tail of output:")
    let tail = output
    let mut shown = 0
    let lines = tail.split("\n")
    let n = len(lines)
    let start = if n > 6 { n - 6 } else { 0 }
    let mut k = start
    while k < n {
        println("           " + lines[k])
        k = k + 1
    }
    return false
}

fn main() {
    let mut root = env("HEXA_FUSION_ROOT")
    if root == "" { root = exec("pwd").trim() }
    println("test_derivative: HEXA_FUSION_ROOT=" + root)

    let cases = [
        ["margin",      "/cli/fusion_margin.hexa",      "",                   "__FUSION_MARGIN__ PASS"],
        ["whatif",      "/cli/fusion_whatif.hexa",      "",                   "__FUSION_WHATIF__ PASS"],
        ["whatif-cf",   "/cli/fusion_whatif.hexa",      "--set lawson_calibration=10 --counter-factual",
                                                                              "__FUSION_WHATIF__ PASS"],
        ["sensitivity", "/cli/fusion_sensitivity.hexa", "",                   "__FUSION_SENSITIVITY__ PASS"],
        ["archetype",   "/cli/fusion_archetype.hexa",   "",                   "__FUSION_ARCHETYPE__ PASS"],
        ["archetype-mk5","/cli/fusion_archetype.hexa",  "--mk mk5",           "__FUSION_ARCHETYPE__ PASS"],
        ["doctor",      "/cli/fusion_doctor.hexa",      "",                   "__FUSION_DOCTOR__ PASS"],
        ["status",      "/cli/fusion_status.hexa",      "",                   "__FUSION_STATUS__ PASS"],
        ["pillar",      "/cli/fusion_pillar.hexa",      "",                   "__FUSION_PILLAR__ PASS"],
        ["pillar-fusion","/cli/fusion_pillar.hexa",     "--pillar fusion",    "__FUSION_PILLAR__ PASS"]
    ]

    let mut pass = 0
    let mut fail = 0
    for c in cases {
        let label = c[0]
        let rel = c[1]
        let extra = c[2]
        let expected = c[3]
        let path = root + rel
        if !_file_exists(path) {
            println("  [SKIP] " + label + "  (module not present: " + path + ")")
            continue
        }
        let out = _run(label, path, extra)
        let ok = _check(label, out, expected)
        if ok { pass = pass + 1 } else { fail = fail + 1 }
    }

    // JSON sentinels too (sample 3)
    let json_cases = [
        ["margin-json",      "/cli/fusion_margin.hexa",      "--json", "__FUSION_MARGIN__ PASS"],
        ["archetype-json",   "/cli/fusion_archetype.hexa",   "--json", "__FUSION_ARCHETYPE__ PASS"],
        ["status-json",      "/cli/fusion_status.hexa",      "--json", "__FUSION_STATUS__ PASS"]
    ]
    for c in json_cases {
        let label = c[0]
        let rel = c[1]
        let extra = c[2]
        let expected = c[3]
        let path = root + rel
        if !_file_exists(path) {
            println("  [SKIP] " + label)
            continue
        }
        let out = _run(label, path, extra)
        let ok = _check(label, out, expected)
        if ok { pass = pass + 1 } else { fail = fail + 1 }
    }

    println("")
    println("test_derivative: " + str(pass) + " passed / " + str(fail) + " failed")
    if fail == 0 {
        println("__HEXA_FUSION_TEST_DERIVATIVE__ PASS")
    } else {
        println("__HEXA_FUSION_TEST_DERIVATIVE__ FAIL")
        exit(1)
    }
}
