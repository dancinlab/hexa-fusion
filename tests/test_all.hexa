#!hexa strict
// hexa-fusion/tests/test_all.hexa — top-level test aggregator.
//
// Runs every tests/test_*.hexa in the repo and aggregates exit codes.
//
// Run:
//   hexa run tests/test_all.hexa
//   HEXA_FUSION_ROOT=/path hexa run tests/test_all.hexa

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_FUSION_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-fusion"
}

let ROOT = _root()
let HEXA = HOME + "/.hx/bin/hexa"

// (filename, expected_sentinel)
let CASES = [
    "test_selftest.hexa|__HEXA_FUSION_TEST_SELFTEST__ PASS",
    "test_derivative.hexa|__HEXA_FUSION_TEST_DERIVATIVE__ PASS",
    "test_lattice.hexa|__HEXA_FUSION_TEST_LATTICE__ PASS",
    "test_calculators.hexa|__HEXA_FUSION_TEST_CALCULATORS__ PASS",
    "test_cli_verify.hexa|__HEXA_FUSION_TEST_CLI_VERIFY__ PASS",
    "test_saturation.hexa|__HEXA_FUSION_TEST_SATURATION__ PASS",
]

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_one(case: str) -> bool {
    let parts = case.split("|")
    let fname = parts[0]
    let sentinel = parts[1]
    let path = ROOT + "/tests/" + fname
    let cmd = "HEXA_FUSION_ROOT=" + shq(ROOT) + " " + shq(HEXA) + " run " + shq(path)
    let r = exec_with_status(cmd + " 2>&1")
    let out = to_string(r[0])
    let code = r[1]
    let has_sent = out.find(sentinel) >= 0
    let pass = code == 0 && has_sent
    let mark = if pass { "PASS" } else { "FAIL" }
    println("  [" + mark + "] " + fname + "  (exit=" + str(code) + ")")
    return pass
}

fn main() {
    println("========================================================================")
    println("  hexa-fusion test_all — run every tests/test_*.hexa")
    println("  root: " + ROOT)
    println("========================================================================")
    let mut ok = 0
    let mut fail = 0
    for c in CASES {
        if run_one(c) { ok = ok + 1 } else { fail = fail + 1 }
    }
    println("========================================================================")
    println("  " + str(ok) + "/" + str(len(CASES)) + " test(s) PASS")
    if fail > 0 {
        eprintln("__HEXA_FUSION_TEST_ALL__ FAIL — " + str(fail) + " test(s) failed")
        exit(1)
    }
    println("__HEXA_FUSION_TEST_ALL__ PASS — full test suite green")
    exit(0)
}
