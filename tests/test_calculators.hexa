#!hexa strict
// hexa-fusion/tests/test_calculators.hexa — calc_* + numerics_* sentinel sweep.
//
// One row per script in verify/ that emits a `__HEXA_FUSION_<NAME>__ PASS`
// sentinel. Each row asserts exit 0 + sentinel string in stdout. Bumps
// per RSC iter (recipe §2 step 4).

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_FUSION_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-fusion"
}

let ROOT = _root()
let HEXA = HOME + "/.hx/bin/hexa"

// (verify/<file>, expected_sentinel)
let CASES = [
    "calc_fusion.hexa|__HEXA_FUSION_CALC_FUSION__ PASS",
    "calc_tabletop.hexa|__HEXA_FUSION_CALC_TABLETOP__ PASS",
    "numerics_fusion.hexa|__HEXA_FUSION_NUMERICS_FUSION__ PASS",
    "numerics_fusion_parity.hexa|__HEXA_FUSION_NUMERICS_FUSION_PARITY__ PASS",
    "numerics_fusion_solver.hexa|__HEXA_FUSION_NUMERICS_FUSION_SOLVER__ PASS",
    "numerics_tabletop.hexa|__HEXA_FUSION_NUMERICS_TABLETOP__ PASS",
]

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_one(case: str) -> bool {
    let parts = case.split("|")
    let fname = parts[0]
    let sentinel = parts[1]
    let path = ROOT + "/verify/" + fname
    let cmd = "HEXA_FUSION_ROOT=" + shq(ROOT) + " " + shq(HEXA) + " run " + shq(path)
    let r = exec_with_status(cmd + " 2>&1")
    let out = to_string(r[0])
    let code = r[1]
    let has_sent = out.find(sentinel) >= 0
    let pass = code == 0 && has_sent
    let mark = if pass { "PASS" } else { "FAIL" }
    println("  [" + mark + "] " + fname + "  (exit=" + str(code) + ")")
    return pass
}

fn main() {
    println("========================================================================")
    println("  hexa-fusion test_calculators — calc_* + numerics_* sentinel sweep")
    println("  root: " + ROOT)
    println("========================================================================")
    let mut ok = 0
    let mut fail = 0
    for c in CASES {
        if run_one(c) { ok = ok + 1 } else { fail = fail + 1 }
    }
    println("========================================================================")
    println("  " + str(ok) + "/" + str(len(CASES)) + " calc/numerics PASS")
    if fail > 0 {
        eprintln("__HEXA_FUSION_TEST_CALCULATORS__ FAIL — " + str(fail) + " script(s) failed")
        exit(1)
    }
    println("__HEXA_FUSION_TEST_CALCULATORS__ PASS")
    exit(0)
}
