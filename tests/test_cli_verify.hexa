#!hexa strict
// hexa-fusion/tests/test_cli_verify.hexa — CLI `verify all` subcommand regression.
//
// Asserts that `hexa-fusion verify all` runs and aggregates 1/1 PASS at iter 1.
// The expected count bumps as new verify/*.hexa scripts are added per recipe §2.

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_FUSION_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-fusion"
}

let ROOT = _root()
let CLI = ROOT + "/cli/hexa-fusion.hexa"
let HEXA = HOME + "/.hx/bin/hexa"

// Expected aggregate count — bump per iter (recipe §2 step 4).
// iter 1 (2026-05-07): lattice = 1
// iter 2 (2026-05-07): + cross-doc = 2
// iter 3 (2026-05-07): + fusion = 3
// iter 4 (2026-05-07): + tabletop = 4
// iter 5 (2026-05-07): + numerics-fusion = 5
// iter 6 (2026-05-07): + numerics-fusion-parity = 6
// iter 7 (2026-05-07): + numerics-fusion-solver = 7
// iter 8 (2026-05-07): + numerics-tabletop = 8
// iter  9 (2026-05-07): + numerics-tabletop-parity = 9
// iter 10 (2026-05-07): + numerics-powerplant     = 10
// iter 11 (2026-05-07): + numerics-powerplant-dse = 11
// iter 12 (2026-05-07): + numerics-cross           = 12
// iter 13 (2026-05-07): + numerics-lattice         = 13
// iter 14 (2026-05-08): + falsifier                = 14
// iter 15 (2026-05-08): + lint-numerics            = 15
// iter 17 (2026-05-08): + numerics-fusion-burnup   = 16  (F1 T2x3, sat-1 close)
// iter 18 (2026-05-08): + numerics-tabletop-solver = 17  (F2 T2x3, sat-1 close)
let EXPECTED_AGG = "PASS:  17/17"

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn main() {
    println("[test_cli_verify] target: " + CLI + " verify all")
    let cmd = "HEXA_FUSION_ROOT=" + shq(ROOT) + " " + shq(HEXA) +
              " run " + shq(CLI) + " verify all"
    let r = exec_with_status(cmd + " 2>&1")
    let out = to_string(r[0])
    let code = r[1]
    let has_aggregate = out.find(EXPECTED_AGG) >= 0
    let pass = code == 0 && has_aggregate
    if pass {
        println("[test_cli_verify] PASS — verify all reports " + EXPECTED_AGG + ", exit 0")
        println("__HEXA_FUSION_TEST_CLI_VERIFY__ PASS")
        exit(0)
    }
    eprintln("[test_cli_verify] FAIL — exit=" + str(code) +
             " aggregate(" + EXPECTED_AGG + ")=" + str(has_aggregate))
    eprintln("--- last lines of stdout ---")
    let lines = out.split("\n")
    let n = len(lines)
    let mut start = n - 20
    if start < 0 { start = 0 }
    let mut i = start
    while i < n { eprintln("    " + lines[i]); i = i + 1 }
    eprintln("__HEXA_FUSION_TEST_CLI_VERIFY__ FAIL")
    exit(1)
}
