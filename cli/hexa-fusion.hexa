        println("  cross-doc       → cross-pillar anchor consistency audit")
        println("  fusion          → D-T pillar n=6 algebraic derivation (master + fuel + Q + B + Lawson + archetype)")
        println("  tabletop        → tabletop p-11B aneutronic n=6 derivation (V + T_opt + Q=τ + power + cost)")
        println("  numerics-fusion → D-T closed-form numerics (T2: math_pure float ↔ int parity, Lawson, Q, Carnot)")
        println("  numerics-fusion-parity → D-T published-machine parity (T2: ITER / JET / KSTAR / SPARC)")
        println("  numerics-fusion-solver → 0D D-T burn ODE solver (T2: RK2 vs analytic, mass balance)")
        println("  numerics-fusion-burnup → D-T burnup integral (T2: Simpson + trapezoid + analytic, 4th-order convergence)")
        println("  numerics-tabletop      → tabletop p-11B numerics (T2: B^4 scaling + Gamow peak + power density)")
        println("  numerics-tabletop-parity → p-11B 4-effort published parity (T2: HB11 / TAE / LPP / ENN)")
        println("  numerics-tabletop-solver → p-11B 0D burn ODE solver (T2: RK4 vs analytic, 3α conservation)")
        println("  numerics-powerplant    → KSTAR-N6 powerplant numerics (T2: P_input → P_th → P_e + Carnot bound)")
        println("  numerics-powerplant-dse → Q-gain DSE (T2: B-quadratic + T-linear scaling, monotonicity, break-even windows)")
        println("  numerics-cross          → cross-pillar numerical anchor (T2: every n=6 float identical across 4 pillars)")
        println("  numerics-lattice        → math_pure stability floor (T2: sqrt/pow/log/exp on n=6 anchors < 1e-9 rel err)")
        println("  numerics-plasma-deep    → plasma_deep + 122-closure depth (T2: 5 decompositions + Mk.I→VII + 11·σ pattern)")
        println("  falsifier               → F-FUSION-1/2/3/4 closure-progress tracker (META)")
        println("  lint-numerics           → every numerics_*.hexa conforms to 5-invariant regression pattern (META)")
        println("  cost: $0 (~2s on Mac)")
    } else if sub == "selftest" {
        println("hexa-fusion selftest [--json]")
        println("  sub-command sentinel sweep — verifies core + derivative modules")
        println("  cost: $0")
    } else if sub == "margin" {
        println("hexa-fusion margin [--json] [--top N]")
        println("  per-row residual / headroom report; sorted tightest first")
        println("  cost: $0 (closed-form arithmetic)")
    } else if sub == "whatif" {
        println("hexa-fusion whatif [--set k=v]... [--counter-factual] [--json]")
        println("  override n=6 lattice (sigma/tau/phi/sopfr/j2/mu/n/lawson_calibration)")
        println("  and re-run the 27-row ledger; diff vs canonical baseline")
        println("  cost: $0")
    } else if sub == "sensitivity" {
        println("hexa-fusion sensitivity [--steps \"0.01,0.05,0.10,0.20\"] [--json]")
        println("  ±-perturbation sweep over each n=6 anchor; surfaces dominant levers")
        println("  cost: $0 (~50 ms)")
    } else if sub == "archetype" {
        println("hexa-fusion archetype [--mk <id>] [--json]")
        println("  Mk.I→Mk.V projector + 122/122 EXACT closure tally")
        println("  cost: $0")
    } else if sub == "doctor" {
        println("hexa-fusion doctor [--strict] [--json]")
        println("  env + module health probe (runtime / modules / hx shim)")
        println("  cost: $0")
    } else if sub == "pillar" {
        println("hexa-fusion pillar [--pillar <id>] [--json]")
        println("  per-pillar deep-dive — fusion / tabletop_fusion / fusion_powerplant / plasma_deep")
        println("  cost: $0")
    } else {
        cmd_help()
    }
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_fusion_cli", "hexa_fusion_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        if sub == "--help" || sub == "-h" || sub == "help" {
            cmd_help()
        } else {
            cmd_subhelp(sub)
        }
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status_full(a)
    } else if sub == "ledger" {
        cmd_ledger(a)
    } else if sub == "calc" {
        cmd_calc(a)
    } else if sub == "dse" {
        cmd_dse(a)
    } else if sub == "verify" {
        cmd_verify(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else if sub == "margin" {
        cmd_margin(a)
    } else if sub == "whatif" {
        cmd_whatif(a)
    } else if sub == "sensitivity" {
        cmd_sensitivity(a)
    } else if sub == "archetype" {
        cmd_archetype(a)
    } else if sub == "doctor" {
        cmd_doctor(a)
    } else if sub == "pillar" {
        cmd_pillar(a)
    } else {
        eprintln("hexa-fusion: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-fusion help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
